<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <link rel="icon" href="/img-core/favicon.png">
    <meta name="theme-color" content="#ef6e17" />

    <title>
        {% block title %}My DigiTrans |
        {{ page|capitalize }}
        {% endblock %}
    </title>

    {% block stylesheets %}
    <link rel="stylesheet" href="/styles/app.css">
    {% endblock %}

    {% block javascripts %}
    <script src="/js/admin/app.js" defer></script>
    {% endblock %}
</head>

<body id="admin">

    <div class="admin-layout" id="adminContainer">


        {% include 'admin/partials/_sidebar.html.twig' %}



        <div class="main-wrapper">

            {% include 'admin/partials/_topbar.html.twig' %}

            <main class="main-content">
                {% block body %}{% endblock %}
            </main>

            {% include 'admin/partials/_footer.html.twig' %}

        </div>
        <!--main-wrapper-->

    </div>
    <!--admin-layout-->

</body>

</html>