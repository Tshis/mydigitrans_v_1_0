{# templates/admin/agency/trip/index.html.twig #}
{% extends "admin/base.html.twig" %}

{% block javascripts %}
	{{ parent() }}
	<script src="/js/datatable.js" defer></script>
{% endblock %}

{% block body %}
	<div
		class="admin-trip-wrapper container">

		{# --- EN-TÊTE DE LA PAGE --- #}
		<header class="header mb-20">
			<div class="title">
				<h2>
					<i class="fa-solid fa-calendar-days"></i>
					Gestion des Voyages / Départs
				</h2>
				<p>Planifiez les occurrences de départs, suivez les embarquements et filtrez l'historique de votre réseau.
				</p>
			</div>
			<div class="admin-bus-layout-add-action-zone">
				<a href="{{path('admin_agency_trip_add')}}" class="btn btn-success text-size-12">
					<i class="fa-solid fa-plus"></i>
					Planifier un voyage
				</a>
			</div>
		</header>

		{# --- CARTES DE STATISTIQUES --- #}
		<div class="stats-overview-grid">
			<div class="stat-card">
				<div class="stat-icon stat-icon--primary">
					<i class="fa-solid fa-clock"></i>
				</div>
				<div class="stat-details">
					<span class="stat-label">Voyages Planifiés</span>
					<strong class="stat-value">5</strong>
				</div>
			</div>

			<div class="stat-card">
				<div class="stat-icon stat-icon--success">
					<i class="fa-solid fa-bus"></i>
				</div>
				<div class="stat-details">
					<span class="stat-label">En Embarquement</span>
					<strong class="stat-value">1</strong>
				</div>
			</div>

			<div class="stat-card">
				<div class="stat-icon stat-icon--danger">
					<i class="fa-solid fa-circle-check"></i>
				</div>
				<div class="stat-details">
					<span class="stat-label">Voyages Terminés</span>
					<strong class="stat-value">124</strong>
				</div>
			</div>
		</div>

		{# --- COMMODITÉ DE RECHERCHE ET DE FILTRE AVANCÉ --- #}
		<div class="trip-filters-card mb-20">
			<form action="">
				<div class="field-group">
					<div class="field">
						<label class="admin-bus-layout-add-label">Rechercher par date exacte</label>
						<input type="date" name="filter_date" class="admin-bus-layout-add-input">
					</div>
					<div class="field">
						<label class="admin-bus-layout-add-label">Filtrer par état opérationnel</label>
						<select name="filter_status" class="admin-bus-layout-add-select">
							<option value="">-- Tous les états --</option>
							<option value="scheduled">Planifiés (Futurs)</option>
							<option value="boarding">En Embarquement</option>
							<option value="completed">Terminés (Passés)</option>
						</select>
					</div>
				</div>
				<div class="field-button-right mt-10">
					<button type="button" class="btn btn-dark">
						<i class="fa-solid fa-magnifying-glass"></i>
						Rechercher...
					</button>
				</div>
			</form>
		</div>

		{# --- TABLEAU DES DONNÉES DATATABLE AVEC SCROLL RESPONSIVE --- #}

		<div class="table-responsive-wrapper">
			<table class="table table-scrollable table-striped js-datatable">
				<thead>
					<tr>
						<th>Date & Départ</th>
						<th>Ligne / Itinéraire</th>
						<th>Véhicule / Équipage</th>
						<th>Remplissage</th>
						<th>Statut</th>
						<th class="text-right">Actions</th>
					</tr>
				</thead>
				<tbody>
					<tr>
						<td>
							<strong>14/07/2026</strong>
							<span class="sub-meta-text">À 14h30</span>
						</td>
						<td>
							<strong>Kinshasa → Kikwit</strong>
							<span class="sub-meta-text">via Kenge</span>
						</td>
						<td>
							<strong>Bus 01</strong>
							(Marcopolo)
							<span class="sub-meta-text">Chauffeur : Jean Mukendi</span>
						</td>
						<td>
							<strong>42 / 54</strong>
							places
							<span class="sub-meta-text">(77%)</span>
						</td>
						<td>
							<span class="badge badge-warning-status">Embarquement</span>
						</td>
						<td class="actions text-right">
							<a href="{{ path('admin_agency_trip_show', {'code': 'trip-07-26-0001-01'}) }}" class="table-action-trigger" title="Détails du voyage">
								<i class="fa-solid fa-eye"></i>
							</a>
						</td>
					</tr>
				</tbody>
			</table>
		</div>


	</div>
{% endblock %}
