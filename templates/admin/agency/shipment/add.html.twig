{# templates/admin/agency/shipment/new.html.twig #}
{% extends "admin/base.html.twig" %}

{% block javascripts %}
	{{ parent() }}
	{# Ce script gère le calcul du prix du fret basé sur le poids et la nature du colis #}
	<script src="/js/admin/shipment-calculator.js" defer></script>
{% endblock %}

{% block body %}
	<div
		class="admin-shipment-creation-scope container">

		{# --- EN-TÊTE DE LA PAGE --- #}
		<header class="header mb-25">
			<a href="{{ path('admin_agency_shipment_index') }}" class="agency-back-action" title="Retour au backoffice">
				<i class="fa-solid fa-arrow-left"></i>
			</a>
			<div class="title">
				<h2>Enregistrement de Fret & Colis (Shipment)</h2>
				<p>Pesez la marchandise, enregistrez les contacts et émettez le Bon de chargement.</p>
			</div>
		</header>

		{# --- FORMULAIRE D'EXPÉDITION --- #}
		<form action="#" method="POST" class="reservation-form">
			<div
				class="reservation-container">

				{# COLONNE GAUCHE : LOGISTIQUE, ACTEURS ET DESCRIPTION DU COLIS #}
				<div
					class="layout-main-panel">

					{# Étape 1 : Affectation au voyage #}
					<div class="card mb-20">
						<h2>Logistique & Expédition</h2>
						<div class="field-group mb-20">
							<div class="field">
								<label>Voyage / Camion / Bus Affecté</label>
								<select name="trip_id" id="shipment-trip-selector" required>
									<option value="">-- Choisir un départ actif --</option>
									<option value="1" data-route-price-kg="500">TRP-2026-0042 (Kinshasa → Kikwit | 14h30)</option>
									<option value="2" data-route-price-kg="400">TRP-2026-0043 (Kinshasa → Matadi | 08h00)</option>
								</select>
							</div>
						</div>
						<div class="field-group">
							<div class="field">
								<label>Lieu de Dépôt</label>
								<select name="departure_agency_id" required>
									<option value="1">Kinshasa (Gare Centrale)</option>
								</select>
							</div>
							<div class="field">
								<label>Lieu de Retrait / Destination</label>
								<select name="arrival_agency_id" required>
									<option value="3">Kikwit (Terminus)</option>
									<option value="2">Kenge (Arrêt Principal)</option>
								</select>
							</div>
						</div>
					</div>

					{# Étape 2 : Les Acteurs (Expéditeur et Destinataire) #}
					<div class="card mb-20">
						<h2>Acteurs du Fret</h2>
						<div class="field-group mb-20">
							<div class="field">
								<label>Nom de l'Expéditeur</label>
								<input type="text" name="sender_name" placeholder="Ex : Mbala Jean" required autocomplete="off">
							</div>
							<div class="field">
								<label>Téléphone Expéditeur</label>
								<input type="tel" name="sender_phone" placeholder="Ex : +243..." required autocomplete="off">
							</div>
						</div>
						<hr class="summary-divider mb-15">
						<div class="field-group">
							<div class="field">
								<label>Nom du Destinataire</label>
								<input type="text" name="receiver_name" placeholder="Ex : Toko Dieudonné" required autocomplete="off">
							</div>
							<div class="field">
								<label>Téléphone Destinataire</label>
								<input type="tel" name="receiver_phone" placeholder="Ex : +243..." required autocomplete="off">
							</div>
						</div>
					</div>

					{# Étape 3 : Spécifications de la Marchandise #}
					<div class="card">
						<h2>Nature & Caractéristiques de la marchandise</h2>
						<div class="field mb-20">
							<label>Description du contenu</label>
							<input type="text" name="package_description" placeholder="Ex : Carton de pièces de rechange, sac de vêtements" required autocomplete="off">
						</div>
						<div class="field-group">
							<div class="field">
								<label>Nature du Colis</label>
								<select name="package_nature" id="package-nature" required>
									<option value="standard" data-nature-surplus="0">Standard (Cartons, Sacs ordinaires)</option>
									<option value="fragile" data-nature-surplus="5000">Fragile / Électronique (+5 000 CDF)</option>
									<option value="perishable" data-nature-surplus="3000">Périssable / Vivres (+3 000 CDF)</option>
								</select>
							</div>
							<div class="field">
								<label>Poids (En Kilogrammes - Kg)</label>
								<input type="number" name="package_weight" id="package-weight" min="1" max="500" placeholder="Ex : 25" required>
							</div>
						</div>
					</div>

				</div>

				{# COLONNE DROITE : LE BON DE CHARGEMENT LOGISTIQUE #}
				<aside class="summary">
					<div class="card summary-sticky-card">
						<h2>Bon de Chargement</h2>

						<div class="reservation-notice-zone mb-20" style="background-color: rgba(22, 163, 74, 0.05); border-left-color: #16a34a;">
							<p class="notice-title" style="color: #16a34a;">
								<i class="fa-solid fa-boxes-packing"></i>
								Prise en charge fret</p>
							<p class="notice-text">Ce reçu temporaire atteste du dépôt du colis. Il devra être présenté en caisse centrale pour acquitter le fret.</p>
						</div>

						<hr class="summary-divider mb-15">

						<ul class="billing-details-list">
							<li>
								<strong>Poids enregistré :</strong>
								<span id="summary-weight">0 Kg</span>
							</li>
							<li>
								<strong>Nature Colis :</strong>
								<span id="summary-nature">Standard</span>
							</li>
						</ul>

						<div class="total">
							Fret estimé :
							<strong id="summary-total-price">0 CDF</strong>
						</div>

						<button class="btn btn-primary btn-full mt-20 py-12">
							<i class="fa-solid fa-file-shield"></i>
							Générer le Bon de Fret
						</button>
					</div>
				</aside>

			</div>
		</form>
	</div>
{% endblock %}
