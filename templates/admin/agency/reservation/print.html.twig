{# templates/admin/agency/reservation/voucher_pdf.html.twig #}
<!DOCTYPE html>
<html>
	<head>
		<style>
			@page {
				size: 80mm auto;
				margin: 0;
			}
			body {
				font-family: 'Courier New', Courier, monospace;
				width: 74mm;
				padding: 4mm;
				font-size: 12px;
				color: #000;
			}
			.text-center {
				text-align: center;
			}
			.bold {
				font-weight: bold;
			}
			.divider {
				border-top: 1px dashed #000;
				margin-block: 8px;
			}
			.voucher-title {
				font-size: 15px;
				margin: 5px 0;
				letter-spacing: 0.5px;
			}
			.seat-box {
				font-size: 22px;
				border: 2px solid #000;
				padding: 4px 10px;
				display: inline-block;
				margin-block: 8px;
			}
			.alert-text {
				font-size: 10px;
				text-transform: uppercase;
				line-height: 1.3;
			}
		</style>
	</head>
	<body>

		<div class="text-center">
			<span class="bold">MYDIGITRANS LOGISTICS</span><br>
			<span>Guichet Réseau Interurbain</span><br>
			<span class="bold voucher-title">BON DE RÉSERVATION</span><br>
			<span class="bold">{{ ticket.ticketCode }}</span>
		</div>

		<div class="divider"></div>

		<div>
			<span class="bold">PASSAGER :</span>
			{{ ticket.reservation.passengerName }}<br>
			<span class="bold">CONTACT  :</span>
			{{ ticket.reservation.passengerPhone }}<br>
			<span class="bold">VOYAGE   :</span>
			{{ ticket.reservation.trip.code }}<br>
			<span class="bold">DÉPART   :</span>
			{{ ticket.reservation.trip.departureDate|date('d/m/Y à H\\hi') }}
		</div>

		<div class="divider"></div>

		<div class="text-center">
			<span class="bold">SIÈGE BLOQUÉ</span><br>
			<div class="seat-box bold">N°
				{{ ticket.seatNumber }}</div>
		</div>

		<div class="divider"></div>

		<div class="bold text-center" style="font-size: 13px; background: #eee; padding: 4px;">
			À PAYER :
			{{ total_calculated_price }}
		</div>

		<div class="divider"></div>

		<div class="text-center alert-text bold">
			⚠️ DOCUMENT SANS VALEUR DE COMPTOIR ⚠️<br>
			Ce bon expire automatiquement le<br>
			{{ ticket.reservation.expiresAt|date('d/m/Y à H\\hi') }}<br>
			si aucun paiement n'est validé à la caisse.
		</div>

	</body>
</html>
