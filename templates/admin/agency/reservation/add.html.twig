{# templates/admin/agency/booking/new.html.twig #}
{% extends "admin/base.html.twig" %}

{% block javascripts %}
{{ parent() }}
{# Ce script écoute le clic sur vos sièges pour mettre à jour la caisse du backoffice #}
<script src="/js/admin/booking-guichet-picker.js" defer></script>
{% endblock %}

{% block body %}
<div class="admin-booking-creation-scope container">

    {# --- EN-TÊTE DE LA PAGE --- #}
    <header class="header mb-25">

        <a href="{{ path('admin_agency_reservation_index') }}" class="agency-back-action" title="Retour au backoffice">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div class="title">
            <h2>Guichet de Vente & Émission de Billets</h2>
            <p>Enregistrez un nouveau voyageur, assignez son siège via le gabarit officiel et encaissez le
                règlement.</p>
        </div>

    </header>

    {# --- FORMULAIRE DE VENTE DIRECTE --- #}
    <form action="#" method="POST" class="reservation-form">
        <div class="reservation-container">

            {# COLONNE GAUCHE : PARAMÈTRES, IDENTITÉ ET VOTRE INCLUSION SEATMAP #}
            <div class="layout-main-panel">

                {# Étape 1 : Affectation du trajet #}
                <div class="card mb-20">
                    <h2>Choix du départ & Trajet</h2>
                    <div class="field-group mb-20">
                        <div class="field">
                            <label>Voyage / Occurrence Active</label>
                            <select name="trip_id" id="trip-selector-backoffice" required>
                                <option value="">-- Choisir un voyage --</option>
                                <option value="1">TRP-2026-0042 (Kinshasa → Kikwit | Yutong 55 pl.)</option>
                                <option value="2">TRP-2026-0043 (Kinshasa → Matadi | Mercedes 32 pl.)</option>
                            </select>
                        </div>
                    </div>
                    <div class="field-group">
                        <div class="field">
                            <label>Arrêt de Montée</label>
                            <select name="departure_stop_id" required>
                                <option value="1">Kinshasa (Gare Centrale)</option>
                                <option value="2">Kenge (Arrêt Principal)</option>
                            </select>
                        </div>
                        <div class="field">
                            <label>Arrêt de Descente</label>
                            <select name="arrival_stop_id" required>
                                <option value="3">Kikwit (Terminus)</option>
                            </select>
                        </div>
                    </div>
                </div>

                {# Étape 3 : VOTRE COMPOSANT AUTONOME INCLUS #}
                <div class="card id-seatmap-section">
                    <h2>Choix du siège</h2>

                    {# Rendu dynamique natif de votre système #}
                    {{ include('system/seatmap.html.twig', { 'seatmap': seatmap }) }}

                    {# Input caché pour enregistrer le siège cliqué dans le composant #}
                    <input type="hidden" name="seat_number" id="selected-seat-input-backoffice" required>
                </div>

            </div>

            {# COLONNE DROITE : LE RÉCAPITULATIF FINANCIER & MODES DE PAIEMENT (CAISSE) #}
            <aside class="summary">



                {# Étape 2 : Identité du Voyageur (Enrichie pour le backoffice) #}
                <div class="card mb-20">
                    <h2>Informations du passager</h2>
                    <div class="field-group mb-20">
                        <div class="field">
                            <label>Nom complet</label>
                            <input type="text" name="passenger_name" placeholder="Ex : Jean Mukendi" required
                                autocomplete="off">
                        </div>
                        <div class="field">
                            <label>Téléphone</label>
                            <input type="tel" name="passenger_phone" placeholder="+243..." required autocomplete="off">
                        </div>

                    </div>
                </div>


                <div class="card summary-sticky-card">
                    <h2>Récapitulatif & Caisse</h2>

                    <div class="payment-method-selectors mb-20">
                        <label class="section-micro-label">MODE DE RÈGLEMENT</label>
                        <div class="payment-grid-buttons">
                            <label class="pay-method-item">
                                <input type="radio" name="payment_method" value="cash" checked>
                                <span class="custom-box">
                                    <i class="fa-solid fa-money-bill-wave"></i>
                                    Espèces</span>
                            </label>
                            <label class="pay-method-item">
                                <input type="radio" name="payment_method" value="mobile_money">
                                <span class="custom-box">
                                    <i class="fa-solid fa-mobile-screen"></i>
                                    M-Money</span>
                            </label>
                        </div>
                    </div>

                    <div class="field mb-15">
                        <label class="section-micro-label">Devise de Facturation</label>
                        <select name="currency_code" required>
                            <option value="CDF">CDF (Franc Congolais)</option>
                            <option value="USD">USD (Dollar Américain)</option>
                        </select>
                    </div>

                    <div class="field mb-20">
                        <label class="section-micro-label">Référence Transaction / Id Transfert</label>
                        <input type="text" name="payment_reference" placeholder="Ex: TxID-98342" autocomplete="off">
                    </div>

                    <hr class="summary-divider mb-15">

                    <ul class="billing-details-list">
                        <li>
                            <strong>Départ :</strong>
                            <span id="summary-departure-time">Aujourd'hui à 14h00</span>
                        </li>
                        <li>
                            <strong>Siège réservé :</strong>
                            <span id="summary-seat-number">Aucun</span>
                        </li>
                    </ul>

                    <div class="total">
                        Total :
                        <strong id="summary-total-price">0 CDF</strong>
                    </div>

                    <button class="btn btn-primary btn-full mt-20 py-12">
                        <i class="fa-solid fa-print"></i>
                        Confirmer & Émettre le Billet
                    </button>
                </div>
            </aside>

        </div>
    </form>
</div>
{% endblock %}