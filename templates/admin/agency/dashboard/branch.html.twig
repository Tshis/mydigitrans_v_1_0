{% extends "admin/base.html.twig" %}

{% block javascripts %}
	{# Conserve vos scripts globaux existants #}
	{{ parent() }}

	{# Active AssetMapper et l'écosystème Symfony UX UNIQUEMENT sur ce layout #}
	{{ importmap('app') }}
{% endblock %}

{% block body %}

	{# templates/branch/dashboard.html.twig #}
	<div
		class="a-dashboard-wrapper">

		{# 1. En-tête du Dashboard #}
		<header class="a-dashboard-wrapper_header">
			<h2 class="a-dashboard-wrapper_title">
				<i class="fas fa-building"></i>
				Succursale de Limete (Kinshasa)
			</h2>
			<span class="badge online">Session Ouverte</span>
		</header>

		{# Bloc exclusif au Gérant pour piloter l'état de son outil de travail #}
		<div class="c-cash-control-card">
			<div class="c-cash-control-card_main">
				<div
					class="c-cash-control-card_status">
					{# État Dynamique : changez la classe par 'is-closed' si la caisse est fermée #}
					<span class="status-indicator is-open"></span>
					<div>
						<h4 class="c-cash-control-card_title">Session Financière</h4>
						<p class="c-cash-control-card_text">Caisse ouverte par :
							<strong>Mukendi Jean</strong>
							à 07:15</p>
					</div>
				</div>

				<div
					class="c-cash-control-card_actions">
					{# Ce bouton s'affiche si la caisse est OUVERTE #}
					<button type="button" class="btn btn-danger border-radius-5">
						<i class="fas fa-lock"></i>
						Clôturer la caisse & Arrêter les ventes
					</button>

					{# Ce bouton (masqué par défaut ici) s'affichera si la caisse est FERMÉE #}
					{# 
					            <button type="button" class="btn btn-success border-radius-5">
					                <i class="fas fa-key"></i> Ouvrir la session du jour
					            </button> 
					            #}
				</div>
			</div>
		</div>


		{# 2. Grille de Cartes KPI (Utilise ta classe .c-kpi-card) #}
		<div
			class="a-dashboard-wrapper_kpi-grid">

			{# Recettes du Jour (Double Monnaie) #}
			<div class="c-kpi-card">
				<h4 class="c-kpi-card_title">Recettes du Jour</h4>
				<div class="c-kpi-card_value">
					2.800.000
					<span class="c-kpi-card_unit">FC</span>
				</div>
				<div class="c-kpi-card_conversion">
					~ 1.300
					<span class="c-kpi-card_unit">USD</span>
				</div>
				<div class="c-kpi-card_sub">Objectif journalier atteint à 92%</div>
			</div>

			{# Bus en Exploitation #}
			<div class="c-kpi-card">
				<h4 class="c-kpi-card_title">Flux Logistique</h4>
				<div class="c-kpi-card_value c-kpi-card_value--green">
					8
					<span class="c-kpi-card_unit">Bus</span>
				</div>
				<div class="c-kpi-card_conversion">En route ou au chargement</div>
				<div class="c-kpi-card_sub">0 incident technique signalé</div>
			</div>

			{# Billets Totaux Vendus #}
			<div class="c-kpi-card">
				<h4 class="c-kpi-card_title">Trafic Passagers</h4>
				<div class="c-kpi-card_value c-kpi-card_value--blue">
					342
					<span class="c-kpi-card_unit">Billets</span>
				</div>
				<div class="c-kpi-card_conversion">Flux guichets physiques</div>
				<div class="c-kpi-card_sub">+14% par rapport à hier</div>
			</div>

		</div>

		{# 3. Grille Principale : Graphique Symfony UX + Performance Agents #}
		<div
			class="a-dashboard-wrapper_charts-grid py-20">

			{# Boîte de Graphique (Utilise ta classe .c-chart-box) #}
			<div class="c-chart-box">
				<h3 class="c-chart-box_title">
					<i class="fas fa-chart-line"></i>
					Évolution des Recettes (7 derniers jours)
				</h3>
				<div
					class="c-chart-box_wrapper">
					{# Génération automatique du graphique Symfony UX #}
					{{ render_chart(chart) }}
				</div>
			</div>

			{# Tableau de Performance des Agents (Harmonisé avec ton thème) #}
			<!-- Performance des Agents (Guichetiers) -->
			<section class="table-card">
				<div class="card-header">
					<h3 class="a-dashboard-wrapper_title text-size-18">
						<i class="fas fa-user-shield"></i>
						Performance des Agents
					</h3>
				</div>
				<div class="table-responsive">
					<table class="custom-table">
						<thead>
							<tr>
								<th>Nom Agent</th>
								<th>Billets Vendus</th>
								<th>Chiffre d'Affaires</th>
							</tr>
						</thead>
						<tbody>
							<tr class="branch-row">
								<td data-label="Nom Agent">
									<strong>Mukendi Jean</strong>
								</td>
								<td data-label="Billets Vendus">145 billets</td>
								<td data-label="Chiffre d'Affaires">1.200.000 FC</td>

							</tr>
							<tr class="branch-row">
								<td data-label="Nom Agent">
									<strong>Kabila Sarah</strong>
								</td>
								<td data-label="Billets Vendus">120 billets</td>
								<td data-label="Chiffre d'Affaires">980.000 FC</td>

							</tr>
							<tr class="branch-row">
								<td data-label="Nom Agent">
									<strong>Mpolo Gloire</strong>
								</td>
								<td data-label="Billets Vendus">77 billets</td>
								<td data-label="Chiffre d'Affaires">620.000 FC</td>

							</tr>
						</tbody>
					</table>

				</div>
			</section>

		</div>
		<!--a-dashboard-wrapper_charts-grid-->

		{# 4. Tableau des Prochains Départs de la Succursale #}
		<section class="table-card">
			<div class="card-header">
				<h3 class="a-dashboard-wrapper_title">
					<i class="fas fa-bus"></i>
					Plan de Route & Départs du Jour
				</h3>
			</div>
			<div class="table-responsive">
				<table class="custom-table">
					<thead>
						<tr>
							<th>N° Bus</th>
							<th>Destination</th>
							<th>Heure Départ</th>
							<th>Places Restantes</th>
							<th>Statut</th>
							<th>Action</th>
						</tr>
					</thead>
					<tbody>
						<tr class="branch-row">
							<td data-label="N° Bus">
								<strong>BUS-012 (Mercedes)</strong>
							</td>
							<td data-label="Destination">Matadi</td>
							<td data-label="Heure Départ">07:30</td>
							<td data-label="Places Restantes">4 places</td>
							<td data-label="Statut">
								<span class="badge online">En route</span>
							</td>
							<td data-label="Action">
								<a href="" class="btn btn-primary p-5 border-radius-5 my-10">
									<i class="fa-solid fa-eye"></i>
								</a>
							</td>
						</tr>
						<tr class="branch-row">
							<td data-label="N° Bus">
								<strong>BUS-045 (Toyota)</strong>
							</td>
							<td data-label="Destination">Boma</td>
							<td data-label="Heure Départ">10:00</td>
							<td data-label="Places Restantes">22 places</td>
							<td data-label="Statut">
								<span class="badge warning">Embarquement</span>
							</td>
							<td data-label="Action">
								<a href="" class="btn btn-primary p-5 border-radius-5 my-10">
									<i class="fa-solid fa-eye"></i>
								</a>
							</td>
						</tr>
						<tr class="branch-row">
							<td data-label="N° Bus">
								<strong>BUS-009 (Scania)</strong>
							</td>
							<td data-label="Destination">Kikwit</td>
							<td data-label="Heure Départ">14:15</td>
							<td data-label="Places Restantes">45 places</td>
							<td data-label="Statut">
								<span class="badge offline">Planifié</span>
							</td>
							<td data-label="Action">
								<a href="" class="btn btn-primary p-5 border-radius-5 my-10">
									<i class="fa-solid fa-eye"></i>
								</a>
							</td>
						</tr>
					</tbody>
				</table>
			</div>
		</section>

	</div>


{% endblock %}
