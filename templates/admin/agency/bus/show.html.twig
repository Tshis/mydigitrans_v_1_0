{# templates/admin/agency/bus/show.html.twig #}
{% extends "admin/base.html.twig" %}

{% block javascripts %}
{{ parent() }}
<script src="/js/admin/bus_profil.js" defer></script>
<script src="/js/seatmap.js" defer></script>
{% endblock %}

{% block body %}
<div class="agency-bus-profile-scope">
	<div class="agency-bus-profile-container">

		{# --- EN-TÊTE --- #}
		<header class="agency-bus-profile-header">
			<a href="{{ path('admin_agency_bus_index') }}" class="agency-bus-profile-back">
				<i class="fa-solid fa-arrow-left"></i>
			</a>
			<div class="bus-info text-center">
				<h2 class="agency-bus-profile-title">Fiche Véhicule :
					{{ bus_code }}</h2>
				<p class="agency-bus-profile-subtitle">Gestion et suivi technique de l'unité de transport</p>
				<p class="text-dark text-size-13 my-10">Ligne d'attache : Matadi - Kinshasa</p>
			</div>
			<div class="agency-bus-profile-status-badge-zone">
				<span class="agency-bus-state-badge agency-bus-state-badge--on-route" id="current-global-status">
					En route
				</span>
			</div>
		</header>

		{# --- FORMULAIRES & BLOCS --- #}
		<div class="agency-bus-profile-layout">

			<div class="left-side">

				{# COLONNE SUPERIEURE : FORMULAIRE #}
				<div class="agency-bus-profile-card">
					<h3 class="agency-bus-profile-card-title">
						<i class="fa-solid fa-pen-to-square"></i>
						Modifier les informations du Bus
					</h3>
					<form id="agency-bus-update-form" class="agency-bus-profile-form" method="POST" action="#">

						<div class="field mb-20">
							<label class="agency-bus-profile-form-label">Numéro de Plaque d'Immatriculation</label>
							<input type="text" name="update_plate" class="agency-bus-profile-form-input"
								value="5412AB/01" required>
						</div>

						<div class="field mb-20">
							<label class="agency-bus-profile-form-label">Marque & Modèle Commercial</label>
							<input type="text" name="update_model" class="agency-bus-profile-form-input"
								value="Mercedes-Benz Marcopolo" required>
						</div>

						<div class="field-group">
							<div class="field mb-20">
								<label class="agency-bus-profile-form-label">Succursale Actuelle</label>
								<select name="mutate_branch" class="agency-bus-profile-form-select">
									<option value="Limete" selected>Limete (Kinshasa)</option>
									<option value="Matadi">Matadi</option>
									<option value="Boma">Boma</option>
								</select>
							</div>

							<div class="field mb-20">
								<label class="agency-bus-profile-form-label">Chauffeur Titulaire</label>
								<select name="assign_driver" class="agency-bus-profile-form-select">
									<option value="1" selected>Ilunga Dieudonné</option>
									<option value="2">Mvumbi Blaise</option>
									<option value="3">Nsimba Gabriel</option>
									<option value="none">-- Aucun --</option>
								</select>
							</div>
						</div>

						<div class="field mb-20">
							<label class="agency-bus-profile-form-label">Ligne / Trajet Régulier Affecté</label>
							<select name="assign_route" class="agency-bus-profile-form-select">
								<option value="kin-mat" selected>Kinshasa ⇄ Matadi (Route Nationale 1)</option>
								<option value="kin-bom">Kinshasa ⇄ Boma</option>
								<option value="mat-bom">Matadi ⇄ Boma</option>
								<option value="kin-kik">Kinshasa ⇄ Kikwit</option>
								<option value="none">-- En réserve (Aucune ligne fixe) --</option>
							</select>
							<small class="agency-bus-help-text">Définir une ligne par défaut pré-remplira
								automatiquement ce bus lors de la création d'un voyage.</small>
						</div>

						<div class="field-button-right">
							<button type="submit" class="btn btn-success text-size-12">
								<i class="fa-solid fa-floppy-disk"></i>
								Enregistrer les modifications
							</button>
						</div>
					</form>
				</div>


				{# COLONNE INFERIEURE : MAINTENANCE #}
				<div class="agency-bus-profile-card">
					<h3 class="agency-bus-profile-card-title" id="maintenance-card-title">
						<i class="fa-solid fa-wrench"></i>
						État Technique & Garage
					</h3>

					<div id="bus-operational-box" class="agency-bus-maintenance-status-box">
						<p>Le véhicule est actuellement opérationnel sur le réseau national.</p>
						<button type="button" id="btn-trigger-panic" class="btn btn-danger btn-full text-size-12">
							<i class="fa-solid fa-triangle-exclamation"></i>
							Déclarer une panne / Envoyer au garage
						</button>
					</div>

					<div id="bus-broken-box" class="agency-bus-maintenance-status-box border-danger">
						<!--Etat de la panne (description)-->
						<p class="text-danger-custom">⚠️
							<strong>Immobilisé :</strong>
							<span id="current-fault-text">Panne d'alternateur sur la RN1.</span>
						</p>
						<button type="button" id="btn-trigger-resolve" class="btn btn-success btn-full text-size-12">
							<i class="fa-solid fa-circle-check"></i>
							Résoudre la panne / Remettre en service
						</button>
					</div>

					{# Volet 1 : Déclaration #}
					<div id="panic-action-panel" class="agency-bus-panic-panel">

						<form action="">

							<div class="field">
								<label>Nature de l'avarie</label>
								<textarea id="maintenance-reason" placeholder="Détaillez la panne..."
									rows="3"></textarea>
							</div>

							<div class="field-button-right my-5">
								<button type="button" id="btn-cancel-panic"
									class="btn btn-dark text-size-14">Annuler</button>
								<button type="button" id="btn-confirm-maintenance"
									class="btn btn-primary ml-10 text-size-14">Confirmer le
									garage</button>
							</div>
						</form>
					</div>

					{# Volet 2 : Résolution #}
					<div id="resolve-action-panel" class="agency-bus-panic-panel panel-border-success">
						<form action="">

							<div class="field">
								<label>Rapport de réparation / Clôture</label>
								<textarea id="resolution-reason" placeholder="Indiquez les réparations faites..."
									rows="3"></textarea>
							</div>
							<div class="agency-bus-panic-actions">
								<button type="button" id="btn-cancel-resolve"
									class="btn btn-dark text-size-14">Annuler</button>
								<button type="button" id="btn-confirm-resolution"
									class="btn btn-success text-size-14">Valider la
									sortie</button>
							</div>
						</form>
					</div>

				</div>

				{# COLONNE INFERIEURE : DÉCLASSEMENT (ZÔNE CRITIQUE) #}
				<div class="agency-bus-profile-card agency-bus-profile-card--critical">
					<h3 class="agency-bus-profile-card-title text-danger">
						<i class="fa-solid fa-triangle-exclamation"></i> Zone de Danger
					</h3>
					<div class="agency-bus-maintenance-status-box border-dark">
						<p>Le déclassement retire définitivement le bus du réseau actif. Utilisez cette option si le
							véhicule est vendu, détruit ou jugé irréparable.</p>

						<button type="button" id="btn-trigger-decommission"
							class="btn btn-danger btn-full text-size-12">
							<i class="fa-solid fa-trash-can"></i> Déclasser / Rendre inactif ce bus
						</button>
					</div>

					{# Volet de confirmation du déclassement #}
					<div id="decommission-action-panel" class="agency-bus-panic-panel panel-border-danger hidden">
						<form action="">
							<div class="field mb-20">
								<label class="agency-bus-profile-form-label text-danger">Motif du déclassement
									définitif</label>
								<select id="decommission-reason-select" class="agency-bus-profile-form-select">
									<option value="sold">Véhicule vendu / Cédé</option>
									<option value="scrapped">Véhicule irréparable (Épave / Réforme)</option>
									<option value="expired">Fin de contrat de leasing / Retrait</option>
								</select>
							</div>
							<div class="agency-bus-panic-actions">
								<button type="button" id="btn-cancel-decommission"
									class="btn btn-dark text-size-12">Annuler</button>
								<button type="button" id="btn-confirm-decommission"
									class="btn btn-success text-size-12">Confirmer la
									radiation</button>
							</div>
						</form>
					</div>
				</div>


			</div>
			<!--left-side-->

			{# --- COULOIR DE TEST MULTI-MODÈLES --- #}
			<div class="right-side seatmap-section">
				<div class="seatmap-section-header">
					<h4 class="seatmap-section-title">{{ seatmap.name }}</h4>
				</div>

				{# Rendu dynamique des plans des bus en incluant le composant autonome #}
				{{ include('system/seatmap.html.twig', { 'seatmap': seatmap }) }}

			</div>
			<!--right-side-->

		</div>
		{# /agency-bus-profile-layout #}


	</div>
	{# /agency-bus-profile-container #}
</div>
{# /agency-bus-profile-scope #}
{% endblock %}