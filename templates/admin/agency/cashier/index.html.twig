{# templates/admin/agency/cashier/index.html.twig #}
{% extends "admin/base.html.twig" %}

{% block body %}
	<div
		class="admin-cashier-scope container">

		{# --- EN-TÊTE DE LA PAGE --- #}
		<header class="header mb-25">
			<div class="title">
				<h2>
					<i class="fa-solid fa-cash-register"></i>
					Gestion de la Caisse Centrale
				</h2>
				<p>Saisissez ou scannez un code de Bon (Passager ou Colis) pour encaisser les fonds et émettre les titres officiels.</p>
			</div>
		</header>

		{# --- ZONE DE SOURCING DU BON (INTERCEPTION) --- #}
		<div class="trip-filters-card mb-25">
			<form action="#" method="GET" class="field-group">
				<div class="field field-grow-2">
					<label class="admin-bus-layout-add-label">Rechercher un Bon à encaisser</label>
					<input type="text" name="voucher_code" class="admin-bus-layout-add-input" placeholder="Saisissez la référence (Ex: RVS-2026-8943 ou SHP-2026-8942)..." autocomplete="off" value="RVS-2026-8943">
				</div>
				<div class="field-actions">
					<button type="submit" class="btn btn-reset">
						<i class="fa-solid fa-magnifying-glass"></i>
						Intercepter le Bon
					</button>
				</div>
			</form>
		</div>

		{# --- LAYOUT DEUX COLONNES COMPTOIR --- #}
		<div
			class="reservation-container">

			{# COLONNE GAUCHE : FRAGMENT INTERCEPTÉ DYNAMIQUE #}
			<div
				class="layout-main-panel">

				{# Cas 1 : Le document intercepté est un Bon de réservation Passager #}
				<div class="card cashier-document-card">
					<h2>
						<i class="fa-solid fa-file-invoice-dollar"></i>
						Détails du Document Intercepté</h2>

					<div class="field-group mb-20 status-alert-box alert-reservation">
						<div class="meta-item">
							<span class="section-micro-label label-reservation">Nature du document</span>
							<strong class="text-highlight">BON DE RÉSERVATION PASSAGER</strong>
						</div>
						<div class="meta-item">
							<span class="section-micro-label label-reservation">Référence Système</span>
							<strong class="text-highlight">RVS-2026-8943</strong>
						</div>
					</div>

					<div class="field-group mb-20 core-info-grid">
						<div class="field">
							<span class="section-micro-label">Bénéficiaire / Voyageur</span>
							<p class="actor-name">Mputu Antoinette</p>
							<span class="actor-sub-text">+243 897 112 233</span>
						</div>
						<div class="field">
							<span class="section-micro-label">Logistique Associée</span>
							<p class="actor-name">Kinshasa → Kenge</p>
							<span class="actor-sub-text">Bus 01 | Siège 14 (Standard)</span>
						</div>
					</div>

					<div class="field-group core-info-grid">
						<div class="field">
							<span class="section-micro-label">Planification départ</span>
							<p class="actor-name">Départ prévu aujourd'hui à 14h30</p>
						</div>
					</div>
				</div>

				{# Cas 2 : Le document intercepté est un Bon de Fret (Masqué par défaut dans cette vue complète pour l'exemple) #}
				<div class="card cashier-document-card">
					<h2>
						<i class="fa-solid fa-boxes-packing"></i>
						Détails du Fret Intercepté</h2>

					<div class="field-group mb-20 status-alert-box alert-fret">
						<div class="meta-item">
							<span class="section-micro-label label-fret">Nature du document</span>
							<strong class="text-highlight">BON D'EXPÉDITION DE FRET / COLIS</strong>
						</div>
						<div class="meta-item">
							<span class="section-micro-label label-fret">Référence Suivi</span>
							<strong class="text-highlight">SHP-2026-8942</strong>
						</div>
					</div>

					<div class="field-group mb-20 core-info-grid">
						<div class="field">
							<span class="section-micro-label">Expéditeur (Sender)</span>
							<p class="actor-name">Mbala Jean</p>
							<span class="actor-sub-text">+243 812 345 678</span>
						</div>
						<div class="field">
							<span class="section-micro-label">Destinataire (Receiver)</span>
							<p class="actor-name">Toko Dieudonné</p>
							<span class="actor-sub-text">+243 897 654 321</span>
						</div>
					</div>

					<div class="field-group core-info-grid">
						<div class="field">
							<span class="section-micro-label">Marchandise Déclarée</span>
							<p class="actor-name">Carton de pièces de rechange</p>
							<span class="actor-sub-text">Nature : Fragile / Électronique</span>
						</div>
						<div class="field">
							<span class="section-micro-label">Logistique & Pesée</span>
							<p class="actor-name">Poids : 25 Kg</p>
							<span class="actor-sub-text">Itinéraire : Kinshasa → Kikwit</span>
						</div>
					</div>
				</div>


			</div>

			{# COLONNE DROITE : MODULE ENCAISSEMENT ET VALIDATION FINANCIÈRE #}
			<aside class="summary">
				<div class="card summary-sticky-card">
					<h2>Règlement & Caisse</h2>

					<div class="payment-method-selectors mb-20">
						<label class="section-micro-label">MODE DE RÈGLEMENT EFFECTIF</label>
						<div class="payment-grid-buttons">
							<label class="pay-method-item">
								<input type="radio" name="payment_method" value="cash" checked>
								<span class="custom-box">
									<i class="fa-solid fa-money-bill-wave"></i>
									Espèces
								</span>
							</label>
							<label class="pay-method-item">
								<input type="radio" name="payment_method" value="mobile_money">
								<span class="custom-box">
									<i class="fa-solid fa-mobile-screen"></i>
									M-Money
								</span>
							</label>
						</div>
					</div>

					<div class="field mb-15">
						<label class="section-micro-label">Devise Encaissée</label>
						<select name="currency_code" required>
							<option value="CDF">CDF (Franc Congolais)</option>
							<option value="USD">USD (Dollar Américain)</option>
						</select>
					</div>

					<div class="field mb-20">
						<label class="section-micro-label">Référence Transaction / Id Mobile Money</label>
						<input type="text" name="payment_reference" placeholder="Saisir TxID si applicable..." autocomplete="off">
					</div>

					<hr class="summary-divider mb-15">

					<ul class="billing-details-list">
						<li>
							<strong>Statut d'origine :</strong>
							<span class="badge-pending-status">PENDING</span>
						</li>
					</ul>

					<div class="total">
						Montant net à payer :
						<strong>45 000 CDF</strong>
					</div>

					<button type="submit" class="btn btn-full mt-20 py-12">
						<i class="fa-solid fa-cash-register"></i>
						Encaisser & Émettre le Titre
					</button>
				</div>
			</aside>

		</div>
	</div>
{% endblock %}
