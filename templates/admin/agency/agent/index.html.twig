{% extends "admin/base.html.twig" %}


{% block javascripts %}
	{{parent()}}
	<script src="/js/admin/agentDataTable.js" defer></script>
{% endblock %}

{% block body %}

	<div
		class="user-wrapper">

		{# 1. EN-TÊTE DE LA PAGE #}
		<header class="user-wrapper_header">
			<h2 class="user-wrapper_title">
				<i class="fas fa-users-cog"></i>
				Personnel & Agents
			</h2>
			<a href="{{path('admin_agency_agent_add')}}" class="btn btn-success border-radius-5">
				<i class="fas fa-user-plus"></i>
				Ajouter un agent
			</a>
		</header>

		{# 2. STRUCTURE DATATABLE COMPACTE ET PRO #}
		<div class="c-datatable my-20">
			<div class="c-datatable_header">
				<div class="c-datatable_search">
					<input type="text" placeholder="Rechercher un agent (nom, matricule, tel...)" class="c-datatable_input">
				</div>

				<div class="c-datatable_filters">
					<select class="c-datatable_select">
						<option value="">Toutes les succursales</option>
						<option value="1">Limete (Kinshasa)</option>
						<option value="2">Gombe (Kinshasa)</option>
						<option value="3">Matadi Centre</option>
					</select>

					<select class="c-datatable_select">
						<option value="">Tous les rôles</option>
						<option value="ROLE_MANAGER">Gérant</option>
						<option value="ROLE_GUICHETIER">Guichetier</option>
						<option value="ROLE_OPERATEUR">Opérateur Fret</option>
						<option value="ROLE_CONVOYEUR">Convoyeur</option>
					</select>
				</div>
			</div>

			{# 3. TABLEAU DES DONNÉES #}
			<div class="table-responsive">
				<table class="custom-table">
					<thead>
						<tr>
							<th style="width: 25%;">Agent</th>
							<th style="width: 20%;">Contact / Téléphone</th>
							<th style="width: 20%;">Succursale</th>
							<th style="width: 15%;">Rôle / Accès</th>
							<th style="width: 10%;">Statut</th>
							<th style="width: 10%; text-align: right;">Actions</th>
						</tr>
					</thead>
					<tbody>

						{# Agent 1 #}
						<tr class="user-row">
							<td>
								<div class="c-user-info">
									<div class="c-user-avatar">
										<i class="fas fa-user"></i>
									</div>
									<div class="c-user-meta">
										<strong>Mukendi Jean</strong>
									</div>
								</div>
							</td>
							<td>
								<span class="c-user-phone">
									<i class="fas fa-phone-alt"></i>
									+243 812 345 678</span>
								<span class="c-user-email">
									<i class="fas fa-envelope"></i>
									j.mukendi@transport.cd</span>
							</td>
							<td>
								<span class="c-user-branch">
									<i class="fas fa-building"></i>
									Limete</span>
							</td>
							<td>
								<span class="badge-role badge-role--guichetier">Guichetier</span>
							</td>
							<td>
								<span class="badge online">Actif</span>
							</td>
							<td class="text-right">
								<div class="c-table-actions">
									<a href="{{path('admin_agency_agent_edit',{code:'xyz-001'})}}" class="btn btn-gray btn-xs" title="Modifier">
										<i class="fas fa-edit"></i>
									</a>
									<a href="{{path('admin_password_reset',{code:'xyz-001'})}}" class="btn btn-dark btn-xs" title="Password">
										<i class="fas fa-key"></i>
									</a>
									<a type="button" class="btn btn-danger btn-xs" title="Bloquer">
										<i class="fas fa-user-slash"></i>
									</a>
									<a type="button" class="btn btn-primary btn-xs" title="Permission">
										<i class="fas fa-gears"></i>
									</a>
								</div>
							</td>
						</tr>

						{# Agent 2 #}
						<tr class="user-row row-suspended">
							<td>
								<div class="c-user-info">
									<div class="c-user-avatar">
										<i class="fas fa-user-slash"></i>
									</div>
									<div class="c-user-meta">
										<strong>Kabila Sarah</strong>
									</div>
								</div>
							</td>
							<td>
								<span class="c-user-phone">
									<i class="fas fa-phone-alt"></i>
									+243 899 876 543</span>
								<span class="c-user-email">
									<i class="fas fa-envelope"></i>
									s.kabila@transport.cd</span>
							</td>
							<td>
								<span class="c-user-branch">
									<i class="fas fa-building"></i>
									Matadi Centre</span>
							</td>
							<td>
								<span class="badge-role badge-role--convoyeur">Convoyeur</span>
							</td>
							<td>
								<span class="badge offline">Bloqué</span>
							</td>
							<td class="text-right">
								<div class="c-table-actions">
									<a href="{{path('admin_agency_agent_edit',{code:'xyz-001'})}}" class="btn btn-gray btn-xs" title="Modifier">
										<i class="fas fa-edit"></i>
									</a>
									<a href="{{path('admin_password_reset',{code:'xyz-001'})}}" class="btn btn-dark btn-xs" title="Password">
										<i class="fas fa-key"></i>
									</a>
									<a type="button" class="btn btn-success btn-xs" title="Débloquer">
										<i class="fas fa-user-check"></i>
									</a>
									<a type="button" class="btn btn-primary btn-xs" title="Permission">
										<i class="fas fa-gears"></i>
									</a>
								</div>
							</td>
						</tr>


					</tbody>
				</table>
			</div>

			{# 4. PIED DE LA DATATABLE #}
			<div class="c-datatable_footer">
				<span class="c-datatable_info">Affichage de 1 à 2 sur 45 agents</span>
				<div class="c-datatable_pagination">
					<button type="button" class="btn btn-secondary btn-xs" disabled>
						<i class="fas fa-chevron-left"></i>
					</button>
					<button type="button" class="btn btn-primary btn-xs">1</button>
					<button type="button" class="btn btn-secondary btn-xs">2</button>
					<button type="button" class="btn btn-secondary btn-xs">
						<i class="fas fa-chevron-right"></i>
					</button>
				</div>
			</div>
		</div>
	</div>


{% endblock %}
