{% extends "public/base.html.twig" %}

{% block body %}

<div class="contact">

    <section class="page-header container">
        <h1>Contactez l’équipe Mydigitrans</h1>
        <p>Support technique, partenariat ou informations générales</p>
    </section>

    <section class="contact-container">

        <!-- FORMULAIRE -->
        <form class="contact-form">
            <h3>
                <i class="fas fa-envelope"></i>
                Envoyer un message
            </h3>

            <div class="field mb-25">
                <label>Nom complet</label>
                <input type="text" required>
            </div>

            <div class="field mb-25">
                <label>Email</label>
                <input type="email" required>
            </div>

            <div class="field mb-25">
                <label>Objet</label>
                <select required>
                    <option value="">-- Sélectionner --</option>
                    <option>Support technique</option>
                    <option>Partenariat</option>
                    <option>Demande commerciale</option>
                    <option>Autre</option>
                </select>
            </div>

            <div class="field mb-25">
                <label>Message</label>
                <textarea rows="5" required></textarea>
            </div>

            <button class="btn btn-primary btn-full">Envoyer le message</button>
        </form>

        <!-- INFOS -->
        <div class="contact-info">

            <div class="card">
                <div class="icon"><i class="fas fa-phone-volume"></i></div>
                <h3>Téléphone</h3>
                <p>+ 243 81 000 00 00</p>
            </div>
            <!--card-->

            <div class="card">
                <div class="icon"><i class="fa-solid fa-envelope"></i></div>
                <h3>Adresse email</h3>
                <p>Support@mydigitrans.com</p>
            </div>
            <!--card-->

            <div class="card">
                <div class="icon"><i class="fa-solid fa-location-dot"></i></div>
                <h3>Localisation</h3>
                <p>Kinshasa - RDC</p>
            </div>
            <!--card-->

        </div>
        <!--contact-info-->

    </section>

</div>
<!--contact-->


{% endblock %}