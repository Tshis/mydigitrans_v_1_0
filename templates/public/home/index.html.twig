<section class="agency">

    <div class="container agency-box">

        <h2>Une solution pour les agences de transport</h2>

        <p>

            Gérez vos bus, trajets, ventes et statistiques sur une seule plateforme.

        </p>

        <button class="btn-primary">Créer mon agence</button>

    </div>

</section>


<section class="business">

    <div class="container business-content">

        <h2>Gagnez de l'argent avec MyDigitrans</h2>

        <p>

            Devenez apporteur d'affaires et recevez des commissions.

        </p>

        <button class="btn-outline">Devenir partenaire</button>

    </div>

</section>


<footer>

    <div class="container footer">

        <div>

            <h3>Mydigitrans</h3>

            <p>La plateforme digitale du transport.</p>

        </div>

        <div>

            <h4>Navigation</h4>

            <ul>

                <li>Accueil</li>
                <li>Trajets</li>
                <li>Business</li>

            </ul>

        </div>

        <div>

            <h4>Contact</h4>

            <ul>

                <li>Email</li>
                <li>WhatsApp</li>

            </ul>

        </div>

    </div>

</footer>


{% endblock %}