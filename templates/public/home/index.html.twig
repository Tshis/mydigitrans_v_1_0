{% extends "public/base.html.twig" %}


{% block body %}

<div class="home">

    <section class="page-header hero">

        <div class="container hero-grid">

            <div class="hero-text">

                <h1>La plateforme digitale du transport et du business</h1>

                <p>
                    Réservez simplement, gérez efficacement et gagnez des commissions avec MyDigitrans
                </p>

                <div class="hero-actions">

                    <a class="btn btn-primary py-12">Rechercher un trajet</a>

                    <a class="btn btn-white py-12">Créer une agence</a>

                </div>

            </div>
            <!--hero-text-->


            <div class="hero-image">

                <div class="hero-card">

                    <h3 class="mb-10">Trouvez votre trajet en quelques secondes</h3>

                    <form action="">

                        <div class="field mb-10">
                            <input placeholder="Ville de départ">
                        </div>

                        <div class="field mb-10">
                            <input placeholder="Destination">
                        </div>

                        <div class="field mb-10">
                            <input type="date">
                        </div>

                        <button class="btn btn-primary py-10 btn-full">Rechercher</button>
                    </form>

                </div>
                <!--hero-card-->
            </div>
            <!--hero-image-->

        </div>

    </section>
    <!--hero-->


</div>
<!--home-->


<section class="features">

    <div class="container">

        <h2>Pourquoi choisir MyDigitrans</h2>

        <div class="features-grid">

            <div class="card">

                <h3>🚍 Réservation rapide</h3>

                <p>Trouvez facilement les trajets disponibles.</p>

            </div>


            <div class="card">

                <h3>📦 Gestion colis</h3>

                <p>Envoyez et suivez vos colis facilement.</p>

            </div>


            <div class="card">

                <h3>🏢 Gestion d'agence</h3>

                <p>Outil complet pour gérer vos bus et trajets.</p>

            </div>


            <div class="card">

                <h3>💰 Business</h3>

                <p>Gagnez des commissions avec notre réseau.</p>

            </div>

        </div>

    </div>

</section>


