{% extends "base.html.twig" %}


{% block body %}

	<!DOCTYPE html>
	<html lang="fr">
		<head>
			<meta charset="UTF-8">
			<meta name="viewport" content="width=device-width, initial-scale=1.0">
			<title>Mydigitrans - Plateforme de transport</title>

			<link rel="stylesheet" href="style.css">

		</head>

		<body>

			<header>
				<nav class="container nav">

					<div class="logo">MYDIGITRANS</div>

					<ul class="menu">
						<li>
							<a href="#">Accueil</a>
						</li>
						<li>
							<a href="#">Trajets</a>
						</li>
						<li>
							<a href="#">Comment ça marche</a>
						</li>
						<li>
							<a href="#">Business</a>
						</li>
						<li>
							<a href="#">Contact</a>
						</li>
					</ul>

					<div class="nav-actions">
						<a class="login">Connexion</a>
						<a class="cta">Créer une agence</a>
					</div>

				</nav>
			</header>


			<section class="hero">

				<div class="container hero-content">

					<h1>La plateforme digitale du transport</h1>

					<p>
						Réservez vos trajets, gérez votre agence de transport et développez votre réseau avec Mydigitrans.
					</p>

					<div class="hero-buttons">
						<button class="btn-primary">Rechercher un trajet</button>
						<button class="btn-secondary">Créer une agence</button>
					</div>

				</div>

			</section>


			<section class="search">

				<div class="container">

					<form class="search-box">

						<input type="text" placeholder="Ville de départ">

						<input type="text" placeholder="Destination">

						<input type="date">

						<button>Rechercher</button>

					</form>

				</div>

			</section>


			<section class="features">

				<div class="container">

					<h2>Pourquoi choisir Mydigitrans</h2>

					<div class="features-grid">

						<div class="feature">
							<h3>Réservation rapide</h3>
							<p>Trouvez et réservez vos trajets facilement.</p>
						</div>

						<div class="feature">
							<h3>Gestion des colis</h3>
							<p>Envoyez et suivez vos colis en toute simplicité.</p>
						</div>

						<div class="feature">
							<h3>Gestion d'agence</h3>
							<p>Solution complète pour les agences de transport.</p>
						</div>

						<div class="feature">
							<h3>Business rentable</h3>
							<p>Gagnez des commissions avec notre réseau.</p>
						</div>

					</div>

				</div>

			</section>


			<section class="how">

				<div class="container">

					<h2>Comment ça marche</h2>

					<div class="steps">

						<div class="step">
							<h3>1. Recherchez</h3>
							<p>Choisissez votre trajet et votre date.</p>
						</div>

						<div class="step">
							<h3>2. Réservez</h3>
							<p>Sélectionnez votre siège et confirmez.</p>
						</div>

						<div class="step">
							<h3>3. Voyagez</h3>
							<p>Présentez votre billet et profitez du voyage.</p>
						</div>

					</div>

				</div>

			</section>


			<section class="agency">

				<div class="container agency-content">

					<h2>Une solution pour les agences</h2>

					<p>
						Digitalisez la gestion de votre agence de transport avec Mydigitrans.
					</p>

					<button class="btn-primary">Créer mon agence</button>

				</div>

			</section>


			<section class="business">

				<div class="container">

					<h2>Gagnez de l'argent avec Mydigitrans</h2>

					<p>
						Devenez apporteur d'affaires et recevez des commissions sur chaque vente.
					</p>

					<button class="btn-secondary">Devenir partenaire</button>

				</div>

			</section>


			<footer>

				<div class="container footer">

					<div>

						<h3>Mydigitrans</h3>

						<ul>
							<li>Accueil</li>
							<li>Trajets</li>
							<li>Business</li>
							<li>Contact</li>
						</ul>

					</div>

					<div>

						<h3>Agences</h3>

						<ul>
							<li>Créer une agence</li>
							<li>Fonctionnalités</li>
							<li>Tarifs</li>
						</ul>

					</div>

					<div>

						<h3>Support</h3>

						<ul>
							<li>Contact</li>
							<li>Assistance</li>
						</ul>

					</div>

				</div>

			</footer>


		</body>
	</html>

{% endblock %}
