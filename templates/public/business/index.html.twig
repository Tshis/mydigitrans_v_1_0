{% extends "public/base.html.twig" %}


{% block body %}

<div class="public-business">

    <section class="page-header container">

        <h1>Gagnez de l'argent avec MyDigitrans</h1>

        <p class="subtitle">
            Rejoignez notre réseau et générez des revenus grâce au transport.
        </p>
    </section>
    <!--page-header-->

    <section class="how-earn">

        <div class="container">

            <h2>Comment gagner des commissions</h2>

            <div class="timeline">

                <div class="step">
                    <div class="circle">1</div>
                    <h3>Inscription</h3>
                    <p>Créez votre compte partenaire gratuitement.</p>
                </div>

                <div class="line"></div>

                <div class="step">
                    <div class="circle">2</div>
                    <h3>Invitez</h3>
                    <p>Partagez votre lien et développez votre réseau.</p>
                </div>

                <div class="line"></div>

                <div class="step">
                    <div class="circle">3</div>
                    <h3>Activité</h3>
                    <p>Les agences vendent billets et colis.</p>
                </div>

                <div class="line"></div>

                <div class="step">
                    <div class="circle">4</div>
                    <h3>Gains</h3>
                    <p>Recevez vos commissions automatiquement.</p>
                </div>

            </div>

        </div>

    </section>
    <!--how-earn-->

    <section class="commission container">


        <h2>Plan de commission</h2>

        <div class="commission-grid">

            <div class="card">
                <h3>Niveau 1</h3>
                <p class="percent">10%</p>
                <p>Sur les ventes directes</p>
            </div>

            <div class="card">
                <h3>Niveau 2</h3>
                <p class="percent">5%</p>
                <p>Sur votre réseau</p>
            </div>

        </div>

        <div class="example">
            <p>
                Si une agence vend 100 billets, vous gagnez une commission sur chaque vente.
                Plus votre réseau grandit, plus vos revenus augmentent.
            </p>
        </div>

    </section>
    <!--commission-->


    <section class="benefits container">

        <div class="container">

            <h2>Pourquoi rejoindre MyDigitrans ?</h2>

            <div class="benefits-grid">

                <div class="benefit"><i class="fa-solid fa-sack-dollar"></i> Revenus passifs</div>
                <div class="benefit"><i class="fa-solid fa-people-group"></i> Réseau évolutif</div>
                <div class="benefit"><i class="fa-solid fa-chart-line"></i> Croissance illimitée</div>
                <div class="benefit"><i class="fa-solid fa-arrow-up-right-dots"></i> Opportunité digitale</div>

            </div>

        </div>

    </section>
    <!--benfits-->


    <section class="cta-section container">

        <h2>Commencez dès aujourd’hui</h2>

        <a href="{{path('business_onboarding')}}" class="btn btn-primary">Devenir partenaire</a>

    </section>
    <!--cta-section-->

</div>
<!--public-business-->


{% endblock %}