<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

		<link rel="icon" href="/img-core/favicon.png">
		<meta name="theme-color" content="#ef6e17"/>

		<title>
			{% block title %}My DigiTrans |
				{{ page|capitalize }}
			{% endblock %}
		</title>

		{% block stylesheets %}
			<link rel="stylesheet" href="/styles/app.css">
		{% endblock %}

		{% block javascripts %}
			<script src="/js/public/app.js" defer></script>
			<script src="/js/public/backtotop.js" defer></script>
		{% endblock %}
	</head>

	<body>
		<div class="header-content">
			{{ include('/public/partials/_navbar.html.twig') }}
			<!-- navbar -->
		</div>
		<!-- header-content -->

		<div class="main-content"> {% block body %}{% endblock %}
			</div>
			<!--main-content-->

			<div class="page-footer-content">{{ include('/public/partials/_footer.html.twig') }}
			</div>
			<!-- footer -->
		</body>

	</html>
